{
  "name": "@trugamr/sonarr",
  "version": "0.1.0",
  "description": "Typed, Effect-native Sonarr SDK.",
  "keywords": [
    "effect",
    "sdk",
    "servarr",
    "sonarr"
  ],
  "homepage": "https://github.com/Trugamr/mcp-servers/tree/main/packages/sonarr#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trugamr/mcp-servers.git",
    "directory": "packages/sonarr"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./effect": {
      "types": "./dist/effect.d.mts",
      "default": "./dist/effect.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@effect/platform": "0.96.2",
    "effect": "3.21.4"
  },
  "devDependencies": {
    "@trugamr/kit": "workspace:*",
    "@trugamr/testkit": "workspace:*"
  }
}
